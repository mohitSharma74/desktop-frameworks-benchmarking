{
  "name": "desktop-frameworks-benchmarking",
  "private": true,
  "version": "0.1.0",
  "description": "Benchmark identical desktop apps across Electron, Electrobun, and Tauri.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dataset:generate": "node scripts/generate-benchmark-dataset.mjs",
    "electron:dev": "npm --workspace @benchmark/electron-app run dev",
    "electron:build": "npm --workspace @benchmark/electron-app run build",
    "electron:package": "npm --workspace @benchmark/electron-app run package",
    "electrobun:dev": "bun run --cwd apps/electrobun dev",
    "electrobun:build": "bun run --cwd apps/electrobun build",
    "electrobun:package": "bun run --cwd apps/electrobun package",
    "tauri:dev": "npm --workspace @benchmark/tauri-app run dev",
    "tauri:build": "npm --workspace @benchmark/tauri-app run build",
    "tauri:package": "npm --workspace @benchmark/tauri-app run package",
    "benchmark:run": "node scripts/run-benchmark.mjs",
    "benchmark:report": "node scripts/report-benchmark-results.mjs"
  }
}
