{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Desktop Framework Benchmark Tauri",
  "version": "0.1.0",
  "identifier": "com.mohitsharma.desktopframeworkbenchmark.tauri",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 5175",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5175",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Desktop Framework Benchmark",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": [
      "resources/dataset/*"
    ],
    "macOS": {
      "signingIdentity": null
    }
  }
}

