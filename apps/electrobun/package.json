{
  "name": "@benchmark/electrobun-app",
  "private": true,
  "version": "0.1.0",
  "author": "Mohit Sharma",
  "description": "Electrobun host for the desktop benchmark app.",
  "scripts": {
    "dev": "node ../../scripts/prepare-electrobun-assets.mjs && bunx electrobun dev --watch",
    "build": "node ../../scripts/prepare-electrobun-assets.mjs && bunx electrobun build",
    "package": "node ../../scripts/prepare-electrobun-assets.mjs && bunx electrobun build --env=stable"
  },
  "dependencies": {
    "@benchmark/app-shell": "file:../../packages/app-shell",
    "@benchmark/benchmark-core": "file:../../packages/benchmark-core",
    "@benchmark/dataset": "file:../../packages/dataset",
    "@benchmark/mock-api": "file:../../packages/mock-api",
    "@benchmark/workload": "file:../../packages/workload",
    "electrobun": "1.16.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.2"
  }
}
